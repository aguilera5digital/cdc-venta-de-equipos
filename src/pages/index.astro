    <script>
        const marcasTrack = document.getElementById("homeMarcasTrack");
        if (marcasTrack && !marcasTrack.dataset.initialized) {
            marcasTrack.dataset.initialized = "true";
            const visibles = 4;
            const originales = Array.from(marcasTrack.children);
            const clones = originales.slice(0, visibles).map((item) => item.cloneNode(true));
            clones.forEach((clone) => marcasTrack.appendChild(clone));

            let indice = 0;
            const totalOriginales = originales.length;

            const mover = () => {
                indice += 1;
                marcasTrack.style.transform = `translateX(-${(indice * 100) / visibles}%)`;

                if (indice === totalOriginales) {
                    window.setTimeout(() => {
                        marcasTrack.style.transition = "none";
                        indice = 0;
                        marcasTrack.style.transform = "translateX(0)";
                        void marcasTrack.offsetHeight;
                        marcasTrack.style.transition = "transform 500ms ease-out";
                    }, 520);
                }
            };

            window.setInterval(mover, 2500);
        }
    </script>

