---
import Layout from "../layouts/Layout.astro";
import bannerEquipos from "@/assets/images/images-equipos/banner-equipos.jpg";
import iconoCheckServicio from "@/assets/svg/icono-check-servicio.svg";
---

<Layout
  title="Servicios - Medical Más Salud"
  description="Conoce nuestros servicios."
>
  <section class="servicio-banner relative w-full ">
    <div class="relative w-full overflow-hidden">
      <img
        src={bannerEquipos.src ?? bannerEquipos}
        alt="Proyectos integrales de lavandería industrial"
        class="absolute inset-0 w-full h-full object-cover object-center"
        loading="eager"
      />

      <div class="absolute inset-0 bg-[#0b2e4f]/40"></div>

      <div class="relative max-w-7xl mx-auto px-4 py-12 md:py-16">
        <div class="max-w-xl">
          <span class="inline-flex items-center bg-white/15 text-white text-xs font-semibold px-4 py-2 rounded-full">
            PROYECTOS LLAVE EN MANO
          </span>

          <h1 class="mt-5 text-white text-3xl md:text-4xl font-bold leading-tight">
            Proyectos integrales de
            <br />
            lavandería industrial
          </h1>

          <p class="mt-5 text-white/90 text-sm md:text-base leading-relaxed max-w-lg">
            Desarrollamos proyectos completos desde el diseño inicial hasta la puesta en marcha operativa,
            asegurando eficiencia, cumplimiento normativo y continuidad operativa.
          </p>

          <a
            href="#"
            class="inline-flex items-center gap-2 mt-7 bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-[10px] transition-all duration-300"
          >
            Solicitar asesoría
            <span aria-hidden="true">→</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="servicio-estadisticas bg-[#1f6fbe] py-6">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center text-white">
        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="35"
            data-prefix="+"
          >
            +0
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Años de experiencia</p>
        </div>

        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="100"
            data-suffix="%"
          >
            0%
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Proyectos entregados</p>
        </div>

        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="24"
            data-suffix="/7"
          >
            0/7
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Soporte técnico</p>
        </div>

        <div>
          <p
            class="text-4xl md:text-5xl font-bold leading-none"
            data-counter
            data-target="500"
            data-prefix="+"
          >
            +0
          </p>
          <p class="mt-2 text-base md:text-[20px] font-semibold">Equipos instalados</p>
        </div>
      </div>
    </div>
  </section>

  <section class="servicio-incluye bg-[#fff] py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center text-[#1b1e4b] text-3xl md:text-4xl font-bold mb-10">
        ¿Qué incluye?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            <span class="font-bold">Diseño técnico</span> y layout de la lavandería
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            Selección y dimensionamiento de equipos
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            Suministro e <span class="font-bold">instalación completa</span>
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            <span class="font-bold">Coordinación eléctrica</span>, hidráulica y de gas
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            Puesta en marcha y <span class="font-bold">capacitación</span>
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            Acompañamiento <span class="font-bold">post-venta</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="servicio-incluye bg-[#fff] py-6">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center text-[#1b1e4b] text-3xl md:text-4xl font-bold mb-10">
        Valor diferencial
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-5">
        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            <span class="font-bold">Ingeniería aplicada</span> a cada rubro
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            <span class="font-bold">Optimización de inversión</span> y operación
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            Coordinación integral <span class="font-bold">sin múltiples proveedores</span>
          </p>
        </div>

        <div class="bg-white rounded-[14px] border border-gray-100 shadow-sm p-6 flex items-center gap-4">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
            </div>
          </div>
          <p class="font-[500] text-black text-[18px] leading-[1.15]">
            <span class="font-bold">Proyecto estructurado</span> para largo plazo
          </p>
        </div>
      </div>
    </div>
  </section>

  <script>
    const statsSection = document.querySelector(".servicio-estadisticas");
    const counters = document.querySelectorAll("[data-counter]");
    let hasAnimated = false;

    const animateCounters = () => {
      if (hasAnimated) return;
      hasAnimated = true;

      counters.forEach((counterEl) => {
        const target = Number(counterEl.getAttribute("data-target") ?? "0");
        const prefix = counterEl.getAttribute("data-prefix") ?? "";
        const suffix = counterEl.getAttribute("data-suffix") ?? "";

        let current = 0;
        const duration = 1300;
        const start = performance.now();

        const step = (timestamp) => {
          const progress = Math.min((timestamp - start) / duration, 1);
          current = Math.floor(progress * target);
          counterEl.textContent = `${prefix}${current}${suffix}`;

          if (progress < 1) {
            requestAnimationFrame(step);
          } else {
            counterEl.textContent = `${prefix}${target}${suffix}`;
          }
        };

        requestAnimationFrame(step);
      });
    };

    if (statsSection) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateCounters();
              observer.disconnect();
            }
          });
        },
        { threshold: 0.3 },
      );

      observer.observe(statsSection);
    }
  </script>
</Layout>

