---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import whatsappIcon from "../../assets/svg/icono-wsp.svg";
import { getImage } from "@/lib/getImage";

export async function getStaticPaths() {
  const servicios = await getCollection("servicios");
  return servicios.map((servicio: CollectionEntry<"servicios">) => ({
    params: { slug: servicio.id.split("/").filter(Boolean).pop() ?? servicio.id },
    props: { servicio },
  }));
}

interface Props {
  servicio: CollectionEntry<"servicios">;
}

const { servicio } = Astro.props as Props;
const { Content, headings } = await render(servicio);

// Obtener servicios relacionados (excluyendo el actual)
const todasServicios = await getCollection("servicios");
const serviciosRelacionados = todasServicios
  .filter((s: CollectionEntry<"servicios">) => s.id !== servicio.id)
  .slice(0, 4);

// Get images
const mainImage = await getImage(servicio.data.image);
const serviciosRelacionadosConImagenes = await Promise.all(
  serviciosRelacionados.map(async (servicioRelacionado: CollectionEntry<"servicios">) => ({
    ...servicioRelacionado,
    image: await getImage(servicioRelacionado.data.image)
  }))
);
---

<Layout
  title={`${servicio.data.title} - Servicios`}
  description={servicio.data.description}
>
  <div class="min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 w-full">
      <!-- Breadcrumb -->
      <nav class="mb-1">
        <ol class="flex items-center space-x-2 text-sm text-gray-500">
          <li><a href="/" class="hover:text-blue-600">Inicio</a></li>
          <li>/</li>
          <li>
            <a href="/servicios" class="hover:text-blue-600">Servicios</a>
          </li>
          <li>/</li>
          <li class="text-gray-900 font-medium">{servicio.data.title}</li>
        </ol>
      </nav>
      <!-- Título -->
      <div class="mb-8">
        <h1 class="text-2xl md:text-3xl lg:text-[35px] font-bold text-gray-900 mb-4 text-left">
                {servicio.data.title}
        </h1>
      </div>

      <div
        class="grid grid-cols-1 lg:grid-cols-2 gap-8 pt-1 max-w-7xl mx-auto px-4"
      >
        <!--imagen principal -->
        <div class="space-y-6 flex flex-col items-center justify-center">
          {
            mainImage && (
              <div class="overflow-hidden">
                <Image
                  src={mainImage}
                  alt={servicio.data.title}
                  class="w-full h-[367.99px] object-cover"
                />
              </div>
            )
          }

          <!-- Botones de Acción -->
          <div class="sticky top-4 flex flex-col items-center justify-center">
            <div class="space-y-3">
              <a
                href="/contacto"
                class="block w-[367.99px] bg-primary text-white px-4 py-1 rounded-full hover:bg-primary/80 transition-colors font-bold uppercase text-center text-sm"
              >
                cotizar
              </a>

              <a
                href={`https://wa.me/56953281492?text=${encodeURIComponent(servicio.data.whatsappMessage || 'Hola, me interesa este servicio')}`}
                class="flex items-center justify-center w-[367.99px] bg-[#13990A] gap-2 text-white px-4 py-1 rounded-full hover:bg-[#13990A]/80 transition-colors font-bold uppercase text-sm"
              >
                <Image src={whatsappIcon} alt="whatsappIcon" class="w-4 h-4" />
                <span>Contactar</span>
              </a>
            </div>
          </div>
        </div>

        <!-- contenido -->
        <div class="space-y-8">
          <main class="p-8 prose prose-neutral prose-base text-justify max-w-none">
            <Content />
          </main>
        </div>
      </div>

      <!-- Servicios Relacionados -->
      <div class="mt-12 mb-8">
        <h3 class="text-2xl font-bold text-gray-900 mb-6">
            Servicios Relacionados
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            serviciosRelacionadosConImagenes.map((servicioRelacionado) => (
              <a
                href={`/servicios/${servicioRelacionado.id.split("/").filter(Boolean).pop() ?? servicioRelacionado.id}`}
                class="group bg-white rounded-lg shadow-md hover:shadow-xl transition-all duration-300 overflow-hidden flex flex-col"
              >
                {servicioRelacionado.image && (
                  <div class="overflow-hidden">
                    <Image
                      src={servicioRelacionado.image}
                      alt={servicioRelacionado.data.title}
                      class="w-full h-[200px] object-contain group-hover:scale-105 transition-transform duration-300"
                    />
                  </div>
                )}
                <div class="p-4 flex flex-col flex-grow">
                  <h4 class="font-semibold text-lg text-gray-900 mb-2 group-hover:text-blue-600 transition-colors line-clamp-2">
                    {servicioRelacionado.data.title}
                  </h4>
                  <span class="inline-block bg-primary text-white px-4 py-2 rounded-lg group-hover:bg-primary/80 transition-colors text-sm font-semibold text-center mt-auto">
                    Leer Más
                  </span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</Layout>
