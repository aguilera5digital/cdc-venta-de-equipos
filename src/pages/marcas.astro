---
import Layout from "../layouts/Layout.astro";
import { Image } from "astro:assets";
import bannerEquipos from "@/assets/images/images-equipos/banner-equipos.jpg";
import banderaUsa from "@/assets/images/bandera-usa.png";
import lavadoraIndustrial from "@/assets/images/lavadora-industrial.png";
import secadoraCapacidad from "@/assets/images/secadora-capacidad.png";
import lavadoraIntensiva from "@/assets/images/lavadora-intensiva.png";
import iconoCheckServicio from "@/assets/svg/icono-check-servicio.svg";
import logoUnimac from "@/assets/images/images-home/marca-37.png";

---

<Layout
  title="Marcas - Medical Más Salud"
  description="Conoce nuestra sección de marcas."
>
  <section class="banner-marcas bg-[#ffffff] pt-16 pb-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div>
         <div class="flex items-center justify-start ">
            <img src={logoUnimac.src} alt="Ícono llave en mano" class="w-[100px] h-[60px]" loading="lazy" />
          </div>
          <h1 class="text-[#1b1e4b] text-3xl md:text-4xl font-bold leading-tight mb-6 max-w-xl">
            UniMac - Ingeniería americana en lavandería industrial
          </h1>
          <a
            href="#"
            class="inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-[10px] transition-all duration-300"
          >
            Cotiza tu proyecto
            <span class="ml-2" aria-hidden="true">→</span>
          </a>
        </div>

        <div class="flex items-center justify-center">
          <Image
            src={bannerEquipos}
            alt="Equipos industriales de lavanderia"
            class="w-full max-w-[620px] h-auto rounded-[10px] object-cover"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="marcas-procedencia bg-[#f4f4f4] pb-16 pt-16">
    <div class="max-w-7xl mx-auto px-4">
      <div class="bg-white px-6 py-6 md:px-8 md:py-8 md:rounded-tl-[100px] md:rounded-bl-[100px]">
        <div class="flex flex-col md:flex-row md:items-center gap-5">
          <div class="shrink-0">
            <div class="w-24 h-24 rounded-full overflow-hidden bg-white">
              <Image
                src={banderaUsa}
                alt="Bandera de Estados Unidos"
                class="w-full h-full object-cover"
              />
            </div>
          </div>

          <div>
            <h2 class="text-black text-2xl md:text-3xl font-bold mb-2 leading-[1.2]">
              Procedencia y respaldo
            </h2>
            <p class="text-justify text-black text-[14px] leading-[1.35]">
              Marca de origen estadounidense, reconocida mundialmente por su
              robustez, durabilidad y alto desempeño en entornos industriales
              exigentes. UniMac es parte de uno de los mayores fabricantes
              globales de equipos de lavanderia comercial e industrial.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="marcas-equipos-disponibles bg-white py-16">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center text-black text-2xl md:text-4xl font-bold mb-12">
        Equipos disponibles
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 px-10 md:gap-8 ">
        <div class="flex flex-col items-center w-full">
          <div class="w-full max-w-[280px] mb-6">
            <Image
              src={lavadoraIndustrial}
              alt="Lavadora industrial"
              class="w-full h-auto object-contain"
            />
          </div>
          <div class="w-full max-w-sm text-left mb-6">
            <h3 class="leading-[1.25] h-[50px] text-black font-bold text-lg md:text-xl mb-3">
              Lavadoras industriales de alto rendimiento
            </h3>
            <div>
              <p class="text-black text-sm md:text-base">
                Aquí va una breve descripcion de este tipo de producto
              </p>
            </div>
          </div>
          <a
            href="#"
            class="inline-flex items-center justify-center self-center border border-black bg-white text-black font-medium px-6 py-2.5 rounded-[10px] transition-all duration-300 hover:bg-blue-600 hover:text-white hover:border-blue-600"
          >
            Cotiza ahora
          </a>
        </div>

        <div class="flex flex-col items-center w-full">
          <div class="w-full max-w-[280px] mb-6">
            <Image
              src={secadoraCapacidad}
              alt="Secadora de gran capacidad"
              class="w-full h-auto object-contain"
            />
          </div>
          <div class="w-full max-w-sm text-left mb-6">
            <h3 class="leading-[1.25] h-[50px] text-black font-bold text-lg md:text-xl mb-3">
              Secadoras de gran capacidad
            </h3>
            <div>
              <p class="text-black text-sm md:text-base">
                Aquí va una breve descripcion de este tipo de producto
              </p>
            </div>
          </div>
          <a
            href="#"
            class="inline-flex items-center justify-center self-center border border-black bg-white text-black font-medium px-6 py-2.5 rounded-[10px] transition-all duration-300 hover:bg-blue-600 hover:text-white hover:border-blue-600"
          >
            Cotiza ahora
          </a>
        </div>

        <div class="flex flex-col items-center w-full">
          <div class="w-full max-w-[280px] mb-6">
            <Image
              src={lavadoraIntensiva}
              alt="Equipo para operación intensiva"
              class="w-full h-auto object-contain"
            />
          </div>
          <div class="w-full max-w-sm text-left mb-6">
            <h3 class="leading-[1.25] h-auto md:h-[50px] text-black font-bold text-lg md:text-xl mb-3">
              Equipos diseñados para operación intensiva y continua
            </h3>
            <div>
              <p class="text-black text-sm md:text-base">
                Aquí va una breve descripcion de este tipo de producto
              </p>
            </div>
          </div>
          <a
            href="#"
            class="inline-flex items-center justify-center self-center border border-black bg-white text-black font-medium px-6 py-2.5 rounded-[10px] transition-all duration-300 hover:bg-blue-600 hover:text-white hover:border-blue-600"
          >
            Cotiza ahora
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="marcas-por-que-unimac bg-white pb-20">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-center text-[#1b1e4b] text-2xl px-10 md:text-4xl font-bold mb-12">
        ¿Por qué elegir UniMac?
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
        <div class="bg-white rounded-[12px] border border-gray-100 shadow-sm px-6 py-5 flex items-center gap-4">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          <p class="font-semibold text-black text-[16px] md:text-[18px] leading-[1.2]">
            Construcción robusta para uso industrial pesado
          </p>
        </div>

        <div class="bg-white rounded-[12px] border border-gray-100 shadow-sm px-6 py-5 flex items-center gap-4">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          <p class="font-semibold text-black text-[16px] md:text-[18px] leading-[1.2]">
            Tecnología avanzada en eficiencia energética
          </p>
        </div>

        <div class="bg-white rounded-[12px] border border-gray-100 shadow-sm px-6 py-5 flex items-center gap-4">
           <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          <p class="font-semibold text-black text-[16px] md:text-[18px] leading-[1.2]">
            Respaldo técnico y disponibilidad de repuestos
          </p>
        </div>

        <div class="bg-white rounded-[12px] border border-gray-100 shadow-sm px-6 py-5 flex items-center gap-4 md:col-span-1">
          <div class="w-14 h-14 rounded-[10px] bg-blue-50 flex items-center justify-center shrink-0">
            <img src={iconoCheckServicio.src} alt="Ícono llave en mano" class="w-[60px] h-[60px]" loading="lazy" />
          </div>
          <p class="font-semibold text-black text-[16px] md:text-[18px] leading-[1.2]">
            Larga vida útil y confiabilidad operativa
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
