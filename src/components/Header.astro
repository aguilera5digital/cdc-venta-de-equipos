---
import logoCdc from "@/assets/Logo-cdc.png";

// Props
export interface Props {
  title?: string;
  description?: string;
}

const { title = "Editorial Siriza Agaria", description } = Astro.props;
const currentPath = Astro.url.pathname;

const linkClass = (path: string) =>
  `px-4 py-2 rounded-lg font-medium transition-all duration-300 text-sm lg:text-base ${
    currentPath === path
      ? "bg-blue-600 text-white"
      : "text-black hover:bg-blue-100"
  }`;
---

<header
  id="main-header"
  class="fixed top-0 bg-white lg:shadow-md z-50 w-full transition-all duration-500 ease-in-out"
>
  <div class="container mx-auto px-2 lg:px-4">
    <div class="flex items-center justify-between py-4 gap-4">
      <a href="/" class="flex items-center flex-shrink-0">
        <img
          src={logoCdc.src}
          alt="CDC"
          class="w-[140px] h-auto lg:w-[220px]"
          loading="eager"
        />
      </a>

    
      <div class="hidden lg:flex flex-1 justify-center">
        <nav class="flex items-center gap-2 xl:gap-4 whitespace-nowrap overflow-x-auto">

          <a href="/" class={linkClass("/")}>Inicio</a>
          <a href="/empresa" class={linkClass("/empresa")}>CDC Rent</a>
          <a href="/equipos" class={linkClass("/equipos")}>Equipos</a>
          <a href="/servicio" class={linkClass("/servicio")}>Servicios</a>
          <a href="/soluciones" class={linkClass("/soluciones")}>Soluciones</a>
          <a href="/marcas" class={linkClass("/marcas")}>Marcas</a>
          <a href="/proyectos" class={linkClass("/proyectos")}>Proyectos</a>

        </nav>
      </div>

   
      <div class="flex items-center gap-3 lg:gap-4 flex-shrink-0">

        <a
          href="#"
          class="hidden lg:inline-flex items-center justify-center bg-blue-600 hover:bg-blue-700 text-white font-medium px-5 py-2 rounded-lg transition-all duration-300"
        >
          Cotizar
        </a>

        <button
          id="menu-toggle"
          class="lg:hidden text-gray-700 hover:text-blue-600 transition p-2"
          aria-label="Abrir menú"
        >
          <svg
            class="w-8 h-8"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>

  
  <div
    id="mobile-menu"
    class="hidden lg:hidden bg-white border-t border-gray-200 shadow-lg"
  >
    <nav class="container mx-auto px-4 py-6 flex flex-col space-y-3">

      <a href="/" class={linkClass("/")}>Inicio</a>
      <a href="/empresa" class={linkClass("/empresa")}>CDC Rent</a>
      <a href="/equipos" class={linkClass("/equipos")}>Equipos</a>
      <a href="/servicio" class={linkClass("/servicio")}>Servicios</a>
      <a href="/soluciones" class={linkClass("/soluciones")}>Soluciones</a>
      <a href="/marcas" class={linkClass("/marcas")}>Marcas</a>
      <a href="/proyectos" class={linkClass("/proyectos")}>Proyectos</a>

    </nav>
  </div>
</header>

<script>
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");

  menuToggle?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  const menuLinks = mobileMenu?.querySelectorAll("a");
  menuLinks?.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
    });
  });
</script>